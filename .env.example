# .env.example — Copy to .env and fill in your values

# Server
HOSTNAME=mail.yourdomain.com
DOMAIN=yourdomain.com

# Ports
SMTP_PORT=25
SMTP_SUBMISSION_PORT=587
SMTP_TLS_PORT=465
IMAP_PORT=143
IMAP_TLS_PORT=993
API_PORT=3000

# Databases
DATABASE_URL=postgresql://bunmail:bunmail@localhost:5432/bunmail
REDIS_URL=redis://localhost:6379

# TLS Certificates (generate with: bun scripts/gen-keys.ts)
TLS_CERT_PATH=./certs/cert.pem
TLS_KEY_PATH=./certs/key.pem

# DKIM
DKIM_PRIVATE_KEY_PATH=./certs/dkim-private.pem
DKIM_SELECTOR=mail

# Mail Storage
MAIL_DIR=./maildir

# Security
JWT_SECRET=replace-with-a-very-long-random-secret-at-least-32-characters

# Limits
MAX_MESSAGE_SIZE=26214400   # 25MB
MAX_CONNECTIONS_PER_IP=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
